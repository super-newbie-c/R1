#include <stdio.h>

void add(int a, int b) {
printf("Result: %d\n", a + b);
}
void subtract(int a, int b) {
printf("Result: %d\n", a - b);
}
void multiply(int a, int b) {
printf("Result: %d\n", a * b);
}
void divide(int a, int b) {
printf("Result: %d\n", a / b);
}
int main(){
int choice, x = 10, y =5;
void (*operations[4])(int, int) = {add, subtract, multiply, divide};

printf("x = %d, y = %d\n\n", x,y);
printf("Pumili ng numero na naaayon sa gustong operasyon:\n");
printf("0: add\n1: subtract\n2: multiply\n3: divide\n\n");
scanf("%d", &choice);

if (choice >= 0 && choice < 4) {
operations[choice](x,y);
} else {
printf("Hindi mo nasundan ang tagubilin\n");
}

return 0;
}
